{
  "_templateVersion": "1.0.0",
  "name": "Mon Spectacle",
  "lang": "fr",
  "hasPoints": true,

  "theme": {
    "primaryColor": "#00d4ff",
    "backgroundColor": "#1a1a2e",
    "textColor": "#ffffff",
    "customCss": "assets/screen.css",
    "customMobileCss": "assets/mobile.css"
  },

  "assets": [
    { "id": "logo",       "type": "image", "url": "assets/logo.png"       },
    { "id": "bg_scene",   "type": "image", "url": "assets/background.jpg" },
    { "id": "ambiance",   "type": "audio", "url": "assets/ambiance.mp3"   }
  ],

  "scenes": [

    {
      "id": "ACCUEIL",
      "title": "🎭 Accueil",
      "type": "WAITING",
      "uiOverrides": {
        "customHtml": "<div style='display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:40px;'><img src='{{asset:logo}}' alt='Logo' style='width:300px;' /><h1 style='color:#00d4ff;font-size:5rem;margin:0;'>Mon Spectacle</h1><p style='font-size:2rem;opacity:0.7;'>Scannez le QR code pour participer</p></div>",
        "backgroundAsset": "bg_scene",
        "fit": "cover"
      },
      "params": {}
    },

    {
      "id": "ATTENTE",
      "title": "⏳ Attente",
      "type": "WAITING",
      "params": {
        "titleDisplay": "Préparez-vous !",
        "subTitle": "Le prochain jeu commence bientôt",
        "displayTextOnScreen": true
      }
    },

    {
      "id": "PROPOSITION_LIBRE",
      "title": "🎤 Proposition libre",
      "type": "PROPOSAL",
      "params": {
        "titleDisplay": "Proposez un thème !",
        "subTitle": "Soyez créatifs !",
        "theme": "Quel thème pour la prochaine impro ?",
        "maxProposals": 3
      }
    },

    {
      "id": "PROPOSITION_PRESET",
      "title": "🎯 Choix parmi une liste",
      "type": "PROPOSAL",
      "params": {
        "titleDisplay": "Devinez la bonne réponse !",
        "subTitle": "Une seule chance !",
        "theme": "Quelle est la bonne réponse ?",
        "presetDisplayLabel": "✅ La réponse était :",
        "maxProposals": 1,
        "presets": [
          "Réponse A",
          "Réponse B",
          "Réponse C"
        ]
      }
    },

    {
      "id": "BRAVO",
      "title": "🏆 Bravo !",
      "type": "WAITING",
      "params": {
        "titleDisplay": "BRAVO !",
        "subTitle": "Félicitations aux gagnants !",
        "displayTextOnScreen": true
      }
    },

    {
      "id": "PAUSE",
      "title": "☕ Pause",
      "type": "WAITING",
      "params": {
        "titleDisplay": "PAUSE",
        "subTitle": "On revient dans quelques instants !",
        "displayTextOnScreen": true
      }
    },

    {
      "id": "PROMO",
      "title": "📣 Informations",
      "type": "PROMO",
      "params": {
        "title": "Retrouvez-nous !",
        "lines": [
          "Prochaine date : Vendredi 20 juin à 20h",
          "Lieu : Le Théâtre du Centre, 12 rue de la Paix",
          { "text": "📸 Instagram : @mon_spectacle",    "url": "https://instagram.com/mon_spectacle" },
          { "text": "👥 Facebook : Mon Spectacle",       "url": "https://facebook.com/mon_spectacle" },
          { "text": "🌐 mon-spectacle.fr",               "url": "https://mon-spectacle.fr" },
          "Entrée : 10€ / 7€ (tarif réduit)",
          "Réservation conseillée"
        ]
      }
    }

  ]
}
